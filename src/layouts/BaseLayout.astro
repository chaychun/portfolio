---
import "@/styles/globals.css"

interface Props {
  title?: string
  description?: string
}

const {
  title = "Chayut Chunsamphran — Portfolio",
  description = "Portfolio of Chayut Chunsamphran. I design and build calm, opinionated software — frontend and design engineering, based in Bangkok.",
} = Astro.props

const canonical = new URL(Astro.url.pathname, Astro.site)
const image = new URL("/og.png", Astro.site)
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <meta name="author" content="Chayut Chunsamphran" />
    <meta name="theme-color" content="#fafaf9" />
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content="Chayut Chunsamphran" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={image} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:image:alt" content="Chayut Chunsamphran — Portfolio" />
    <meta property="og:locale" content="en_US" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={image} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32.png" />
    <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />
    <link rel="manifest" href="/manifest.json" />
    <link rel="canonical" href={canonical} />
    <title>{title}</title>
  </head>
  <body>
    <slot />
  </body>
</html>
