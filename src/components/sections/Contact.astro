---
import { getCollection } from "astro:content"

import GhostEgg from "@/components/GhostEgg.astro"
import Link from "@/components/Link.astro"
import Container from "@/components/ui/Container.astro"
import Section from "@/components/ui/Section.astro"

const socialLinks = (await getCollection("socialLinks")).sort(
  (a, b) => a.data.order - b.data.order,
)
---

<Section screenLabel="Contact" class="pt-24 pb-16">
  <Container>
    <div
      class="flex flex-col gap-4 border-t border-border pt-6 text-[12px] text-muted-foreground sm:flex-row sm:items-center sm:justify-between sm:gap-6"
    >
      <span>© 2026 Chayut Chunsamphran</span>
      <span
        class="flex flex-col items-start gap-2 sm:flex-row sm:items-center sm:gap-x-4 sm:gap-y-2"
      >
        <GhostEgg />
        {
          socialLinks.map(({ data }) => (
            <Link href={data.href} variant="quiet">
              {data.label}
            </Link>
          ))
        }
      </span>
    </div>
  </Container>
</Section>
