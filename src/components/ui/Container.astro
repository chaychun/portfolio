---
interface Props {
  as?: keyof HTMLElementTagNameMap
  class?: string
}

const { as = "div", class: className = "" } = Astro.props as Props
const Tag = as
---

<Tag
  class:list={[
    "mx-auto w-full max-w-[var(--container-max)] px-[var(--container-gutter)]",
    className,
  ]}
>
  <slot />
</Tag>
