{
  "name": "portfolio",
  "version": "0.0.1",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "build": "turbo build",
    "dev": "turbo dev",
    "playground": "turbo run dev --filter=playground",
    "site": "turbo run dev --filter=site",
    "lint": "oxlint",
    "lint:fix": "oxlint --fix",
    "format": "oxfmt",
    "format:check": "oxfmt --check",
    "check": "oxfmt --check && oxlint",
    "typecheck": "turbo typecheck",
    "postinstall": "git config core.hooksPath .githooks 2>/dev/null || true"
  },
  "devDependencies": {
    "oxfmt": "latest",
    "oxlint": "^1.0.0",
    "oxlint-tailwindcss": "latest",
    "turbo": "^2.8.17",
    "typescript": "5.9.3"
  },
  "engines": {
    "node": ">=20"
  },
  "packageManager": "bun@1.3.8"
}
