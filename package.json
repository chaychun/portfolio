{
  "name": "portfolio",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite dev",
    "dev:lab": "vite --config vite.lab.config.ts",
    "build": "vite build",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit && tsc --noEmit -p lab/tsconfig.json",
    "lint": "oxlint",
    "lint:fix": "oxlint --fix",
    "format": "oxfmt \"**/*.{ts,tsx,js,jsx,mjs,cjs}\"",
    "format:check": "oxfmt --check \"**/*.{ts,tsx,js,jsx,mjs,cjs}\"",
    "check": "oxfmt --check \"**/*.{ts,tsx,js,jsx,mjs,cjs}\" && oxlint",
    "postinstall": "git config core.hooksPath .githooks 2>/dev/null || true"
  },
  "dependencies": {
    "@base-ui/react": "^1.4.1",
    "@mux/mux-player-react": "^3.13.0",
    "@tailwindcss/vite": "^4.1.18",
    "@tanstack/react-router": "^1.167.0",
    "@tanstack/react-start": "^1.167.0",
    "@tanstack/router-plugin": "^1.167.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^1.11.0",
    "motion": "^12.38.0",
    "nitro": "latest",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "tailwind-merge": "^3.5.0",
    "tailwindcss": "^4.1.18",
    "vite-tsconfig-paths": "^5.1.4"
  },
  "devDependencies": {
    "@resvg/resvg-js": "^2.6.2",
    "@types/node": "^25.1.0",
    "@types/react": "^19.2.10",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.1",
    "oxfmt": "latest",
    "oxlint": "^1.0.0",
    "oxlint-tailwindcss": "latest",
    "shadcn": "^4.5.0",
    "tw-animate-css": "^1.4.0",
    "typescript": "^5.9.3",
    "vite": "^7.3.2"
  },
  "engines": {
    "node": ">=20"
  },
  "packageManager": "bun@1.3.8"
}
