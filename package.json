{
  "name": "portfolio",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "astro dev",
    "dev:lab": "astro dev --root lab",
    "build": "bun run build:og && astro build",
    "build:og": "bun scripts/build-og.ts",
    "preview": "astro preview",
    "typecheck": "astro check && astro check --root lab",
    "lint": "oxlint",
    "lint:fix": "oxlint --fix",
    "format": "oxfmt \"**/*.{astro,ts,tsx,js,jsx,mjs,cjs,json,yaml,css}\"",
    "format:check": "oxfmt --check \"**/*.{astro,ts,tsx,js,jsx,mjs,cjs,json,yaml,css}\"",
    "check": "bun run format:check && oxlint && bun run typecheck",
    "postinstall": "git config core.hooksPath .githooks 2>/dev/null || true"
  },
  "dependencies": {
    "@astrojs/react": "^6.0.1",
    "@iconify-json/lucide": "^1.2.118",
    "@mux/mux-player": "^3.13.0",
    "@tailwindcss/vite": "^4.1.18",
    "astro": "^7.1.1",
    "astro-icon": "^1.1.5",
    "motion": "^12.38.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "tailwindcss": "^4.1.18"
  },
  "devDependencies": {
    "@astrojs/check": "^0.9.9",
    "@resvg/resvg-js": "^2.6.2",
    "@types/node": "^25.1.0",
    "@types/react": "^19.2.10",
    "@types/react-dom": "^19.2.3",
    "oxfmt": "latest",
    "oxlint": "^1.0.0",
    "oxlint-tailwindcss": "latest",
    "typescript": "^5.9.3",
    "vite": "^7.3.2"
  },
  "engines": {
    "node": ">=20"
  },
  "packageManager": "bun@1.3.8"
}
