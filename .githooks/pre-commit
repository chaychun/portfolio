#!/usr/bin/env bash
set -euo pipefail
cd "$(git rev-parse --show-toplevel)"

files=$(git diff --cached --name-only --diff-filter=ACMR -- \
  '*.ts' '*.tsx' '*.js' '*.jsx' '*.mjs' '*.cjs')

if [ -n "$files" ]; then
  echo "$files" | xargs bun x oxfmt
  echo "$files" | xargs git add --
fi

bun run lint
